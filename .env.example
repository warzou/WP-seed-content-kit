# WP Seed Content Kit - WordPress audit environment template
#
# This file is safe to commit because it contains no secrets.
# Copy it to .env locally and fill the values only on your machine.
#
# Never commit .env.
# .env local files must stay ignored by Git.
# The audit is read-only by default.

WP_SITE_URL=
WP_ADMIN_URL=
WP_USERNAME=
WP_APP_PASSWORD=
WP_REST_BASE=
WP_TEST_MODE=read-only
WP_ALLOW_WRITES=false
WP_EXPECT_DIVI=false
WP_EXPECT_DIVI_VERSION=
